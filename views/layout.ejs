<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> — CitéCovoit</title>
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .notif-cloche {
      position: relative;
      cursor: pointer;
      font-size: 1.3rem;
      padding: 8px;
      border-radius: 10px;
      transition: background 0.2s;
    }
    .notif-cloche:hover { background: var(--gris-clair); }
    .notif-badge {
      position: absolute;
      top: 2px; right: 2px;
      background: var(--rouge);
      color: white;
      font-size: 0.65rem;
      font-weight: 700;
      width: 18px; height: 18px;
      border-radius: 50%;
      display: flex; align-items: center; justify-content: center;
    }
    .notif-dropdown {
      position: absolute;
      top: 48px; right: 0;
      width: 320px;
      background: white;
      border: 1px solid var(--gris-bord);
      border-radius: 14px;
      box-shadow: 0 8px 40px rgba(0,0,0,0.15);
      display: none;
      z-index: 200;
      overflow: hidden;
    }
    .notif-dropdown.ouvert { display: block; }
    .notif-titre {
      padding: 14px 18px;
      font-weight: 700;
      border-bottom: 1px solid var(--gris-bord);
      font-size: 0.9rem;
    }
    .notif-item {
      padding: 12px 18px;
      border-bottom: 1px solid var(--gris-bord);
      font-size: 0.85rem;
      cursor: pointer;
      transition: background 0.2s;
    }
    .notif-item:hover { background: var(--gris-clair); }
    .notif-item.non-lue { background: #f0fdf4; border-left: 3px solid var(--vert); }
    .notif-date { font-size: 0.75rem; color: var(--texte-gris); margin-top: 4px; }
  </style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar">
  <a href="/" class="logo">🚗 CitéCovoit</a>
  <ul class="nav-links">
    <li><a href="/trajets">Trajets</a></li>
    <li><a href="/about">À propos</a></li>
    <li><a href="/contact">Contact</a></li>
  </ul>
  <div class="nav-boutons">
  <% if (user) { %>
    <% if (user.role === 'admin') { %>
      <a href="/admin" class="btn btn-rouge">🛡️ Admin</a>
    <% } %>
    <% if (user.role === 'conducteur') { %>
      <a href="/trajets/nouveau" class="btn btn-vert">+ Publier</a>
    <% } %>
    <% if (user.role === 'passager') { %>
      <a href="/mes-reservations" class="btn btn-outline">🎫 Mes réservations</a>
    <% } %>
    <div class="notif-cloche" id="notifCloche" onclick="toggleNotifs()">
      🔔
      <span class="notif-badge" id="notifBadge" style="display:none;">0</span>
      <div class="notif-dropdown" id="notifDropdown">
        <div class="notif-titre">Notifications</div>
        <div id="notifListe"><p class="vide" style="padding:16px;">Aucune notification</p></div>
      </div>
    </div>
    <a href="/profil" class="btn btn-outline">👤 <%= user.prenom %></a>
    <a href="/logout" class="btn btn-rouge">Déconnexion</a>
  <% } else { %>
    <a href="/login" class="btn btn-outline">Connexion</a>
    <a href="/register" class="btn btn-vert">Inscription gratuite</a>
  <% } %>
</div>
</nav>

<!-- FLASH MESSAGES -->
<% if (success_msg && success_msg.length > 0) { %>
  <div class="flash flash-succes">✅ <%= success_msg %></div>
<% } %>
<% if (error_msg && error_msg.length > 0) { %>
  <div class="flash flash-erreur">❌ <%= error_msg %></div>
<% } %>

<!-- CONTENU -->
<main><%- body %></main>

<!-- FOOTER -->
<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="logo" style="font-size:1.2rem;">🚗 CitéCovoit</span>
      <p>La plateforme de covoiturage gratuite au Québec & Canada.</p>
    </div>
    <div class="footer-liens">
      <a href="/trajets">Trajets</a>
      <a href="/about">À propos</a>
      <a href="/contact">Contact</a>
      <a href="/register">Inscription</a>
    </div>
    <p class="footer-copy">© 2025 CitéCovoit — Projet scolaire</p>
  </div>
</footer>

<!-- ASSISTANT IA -->
<div id="chat-bulle" onclick="toggleChat()">
  <span id="chat-icone">💬</span>
</div>

<div id="chat-fenetre">
  <div id="chat-header">
    <div style="display:flex; align-items:center; gap:10px;">
      <div style="width:36px;height:36px;background:var(--vert);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:1.1rem;">🚗</div>
      <div>
        <div style="font-weight:700;">Assistant CitéCovoit</div>
        <div style="font-size:0.75rem;opacity:0.8;">● En ligne</div>
      </div>
    </div>
    <button onclick="toggleChat()">✕</button>
  </div>
  <div id="chat-messages">
    <div class="msg msg-bot">Bonjour ! 👋 Je suis l'assistant CitéCovoit. Comment puis-je vous aider ?</div>
  </div>
  <div id="chat-input-zone">
    <input type="text" id="chat-input" placeholder="Posez votre question..." onkeydown="if(event.key==='Enter') envoyerMessage()" />
    <button onclick="envoyerMessage()">➤</button>
  </div>
</div>

<script>
  setTimeout(() => { document.querySelectorAll('.flash').forEach(el => el.remove()) }, 4000)

  function toggleChat() {
    document.getElementById('chat-fenetre').classList.toggle('ouvert')
    if (document.getElementById('chat-fenetre').classList.contains('ouvert')) {
      document.getElementById('chat-input').focus()
    }
  }

  async function envoyerMessage() {
    const input    = document.getElementById('chat-input')
    const messages = document.getElementById('chat-messages')
    const texte    = input.value.trim()
    if (!texte) return
    messages.innerHTML += `<div class="msg msg-user">${texte}</div>`
    input.value = ''
    messages.scrollTop = messages.scrollHeight
    const chargement = document.createElement('div')
    chargement.className = 'msg msg-chargement'
    chargement.id = 'chargement'
    chargement.innerHTML = '<span class="points">...</span>'
    messages.appendChild(chargement)
    messages.scrollTop = messages.scrollHeight
    try {
      const res  = await fetch('/assistant', { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ message: texte }) })
      const data = await res.json()
      document.getElementById('chargement').remove()
      messages.innerHTML += `<div class="msg msg-bot">${data.reponse}</div>`
    } catch {
      document.getElementById('chargement').remove()
      messages.innerHTML += `<div class="msg msg-bot">Désolé, une erreur est survenue.</div>`
    }
    messages.scrollTop = messages.scrollHeight
  }

  <% if (user) { %>
  async function chargerNotifications() {
    try {
      const res  = await fetch('/notifications')
      const data = await res.json()
      const badge = document.getElementById('notifBadge')
      const liste = document.getElementById('notifListe')

      if (data.nonLues > 0) {
        badge.style.display = 'flex'
        badge.textContent = data.nonLues > 9 ? '9+' : data.nonLues
      } else {
        badge.style.display = 'none'
      }

      if (data.notifications.length === 0) {
        liste.innerHTML = '<p class="vide" style="padding:16px;">Aucune notification</p>'
      } else {
        liste.innerHTML = data.notifications.map(n => `
          <div class="notif-item ${n.lu ? '' : 'non-lue'}" onclick="window.location='${n.lien || '/dashboard'}'">
            <div>${n.message}</div>
            <div class="notif-date">${new Date(n.createdAt).toLocaleDateString('fr-CA')}</div>
          </div>
        `).join('')
      }
    } catch(e) {}
  }

  function toggleNotifs() {
    const dd = document.getElementById('notifDropdown')
    dd.classList.toggle('ouvert')
    if (dd.classList.contains('ouvert')) {
      fetch('/notifications/lues', { method: 'POST' })
      document.getElementById('notifBadge').style.display = 'none'
    }
  }

  document.addEventListener('click', e => {
    if (!document.getElementById('notifCloche').contains(e.target)) {
      document.getElementById('notifDropdown').classList.remove('ouvert')
    }
  })

  chargerNotifications()
  setInterval(chargerNotifications, 30000)
  <% } %>
</script>

</body>
</html>