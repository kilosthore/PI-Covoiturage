<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Covoiturage</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark">
  <div class="container">
    <a class="navbar-brand fw-bold" href="/">🚗 Covoiturage</a>

    <div>
      <% if (!user) { %>
        <a href="/login" class="btn btn-outline-light me-2">Connexion</a>
        <a href="/register" class="btn btn-warning">Inscription</a>
      <% } else { %>
        <a href="/dashboard" class="btn btn-outline-light me-2">Dashboard</a>
        <a href="/logout" class="btn btn-danger">Déconnexion</a>
      <% } %>
    </div>
  </div>
</nav>

<div class="container mt-5">
    <%- body %>
</div>

</body>
</html>