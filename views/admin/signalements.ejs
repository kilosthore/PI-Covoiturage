<% layout('layout') %>

<section class="section">
  <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:32px;">
    <div>
      <h2> Signalements</h2>
      <p style="color:var(--texte-gris);">Gestion des conflits entre utilisateurs</p>
    </div>
    <a href="/admin" class="btn btn-gris">← Retour admin</a>
  </div>

  <% if (signalements.length === 0) { %>
    <div class="bloc-dashboard" style="text-align:center; padding:48px;">
      <p style="font-size:2rem;">✅</p>
      <p style="color:var(--texte-gris);">Aucun signalement pour le moment.</p>
    </div>
  <% } else { %>
    <div class="bloc-dashboard">
      <table class="tableau">
        <thead>
          <tr>
            <th>Date</th>
            <th>Signalé par</th>
            <th>Personne signalée</th>
            <th>Trajet</th>
            <th>Raison</th>
            <th>Détails</th>
            <th>Statut</th>
            <th>Action</th>
          </tr>
        </thead>
        <tbody>
          <% signalements.forEach(s => { %>
            <tr>
              <td><%= new Date(s.createdAt).toLocaleDateString('fr-CA') %></td>
              <td><strong><%= s.auteur ? s.auteur.prenom + ' ' + s.auteur.nom : '—' %></strong><br>
                <small style="color:var(--texte-gris);"><%= s.auteur ? s.auteur.email : '' %></small>
              </td>
              <td><strong><%= s.cible ? s.cible.prenom + ' ' + s.cible.nom : '—' %></strong><br>
                <small style="color:var(--texte-gris);"><%= s.cible ? s.cible.email : '' %></small>
              </td>
              <td>
                <% if (s.trajet) { %>
                  <%= s.trajet.villeDepart %> → <%= s.trajet.villeArrivee %><br>
                  <small style="color:var(--texte-gris);"><%= new Date(s.trajet.dateDepart).toLocaleDateString('fr-CA') %></small>
                <% } else { %>—<% } %>
              </td>
              <td>
                <span class="statut <%= s.raison === 'comportement' ? 'statut-annule' : 'statut-en_attente' %>">
                  <%= s.raison.replace('_', ' ') %>
                </span>
              </td>
              <td style="max-width:180px; font-size:0.85rem; color:var(--texte-gris);">
                <%= s.details || '—' %>
              </td>
              <td>
                <span class="statut <%= s.statut === 'traite' ? 'statut-actif' : s.statut === 'rejete' ? 'statut-annule' : 'statut-en_attente' %>">
                  <%= s.statut %>
                </span>
                <% if (s.noteAdmin) { %>
                  <br><small style="color:var(--texte-gris); font-size:0.75rem;">Note: <%= s.noteAdmin %></small>
                <% } %>
              </td>
              <td>
                <% if (s.statut === 'en_attente') { %>
                  <form action="/admin/signalements/<%= s._id %>/traiter" method="POST" style="display:flex; flex-direction:column; gap:6px;">
                    <textarea name="noteAdmin" rows="2" placeholder="Note admin (optionnel)" style="font-size:0.8rem; padding:4px; border-radius:6px; border:1px solid var(--gris-bord); resize:none;"></textarea>
                    <div style="display:flex; gap:6px;">
                      <button name="statut" value="traite" class="btn btn-vert btn-petit">✓ Traité</button>
                      <button name="statut" value="rejete" class="btn btn-rouge btn-petit">✗ Rejeter</button>
                    </div>
                  </form>
                <% } else { %>
                  <span style="color:var(--texte-gris); font-size:0.85rem;">Fermé</span>
                <% } %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>
